# Use localhost when running the API server on your machine.
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/economy_news_tracker?schema=public"
GOOGLE_CLIENT_ID="your-google-client-id"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"
CRAWLING_ARTICLE_URL="https://www.hankyung.com/feed/economy"
CRAWLING_LANGUAGE="ko"
CRAWLING_REGION="KR"
CRAWLING_KEYWORDS="금리,환율,물가,증시,부동산,반도체"
